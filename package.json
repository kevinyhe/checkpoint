{
  "name": "playtestiq-smb-demo",
  "version": "0.1.0",
  "private": true,
  "description": "PlaytestIQ CLI demo for scripted AI-style playtests against Super Mario Bros. World 4-2.",
  "type": "module",
  "bin": {
    "playtestiq-smb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "discover": "node dist/cli.js discover",
    "dev": "tsx src/cli.ts",
    "state-helper": "node tools/state-server.mjs",
    "view": "node dist/cli.js view",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "15.0.0",
    "jsnes": "2.1.0"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.0",
    "@types/node": "^24.10.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
